```mermaid
%%{init: {"flowchart": {"curve": "step"}}}%%
flowchart TB
    %% Стили
    classDef person fill:#08427b,stroke:#052e56,color:#fff
    classDef container fill:#438dd5,stroke:#2b5a8e,color:#fff
    classDef component fill:#85bbf0,stroke:#5b82a8,color:#000
    classDef external fill:#999999,stroke:#666666,color:#fff
    classDef database fill:#438dd5,stroke:#2b5a8e,color:#fff

    User("Пользователь\n[Person]\nВводит ТЗ / Отвечает на вопросы"):::person

    subgraph Client ["Client Application"]
        UI("Web UI / CLI\n[Container]\nЧат с агентами"):::container
    end

    subgraph SystemBoundary ["LocalScript System (Backend)"]
        
        API("API Gateway (FastAPI)\n[Component]\nРоутинг (/generate)"):::component
        Contracts("Contracts Layer (Pydantic)\n[Component]\nВалидация JSON: Header, Payload, Metadata"):::component
        Orchestrator("Orchestrator\n[Component]\nКонтроллер Agentic Loop"):::component
        
        subgraph Storage ["Storage & Context"]
            direction LR
            DB[("SQLite\n(Session History)\nПамять диалогов")]:::database
            VectorDB[("RAG DB\n(Chroma)\nЭмбеддинги примеров кода")]:::database
            Logs[("Local FS\n(Logs / Temp)\nЛоги, Метрики, .lua файлы")]:::database
        end
        
        LLMClient("LLM Client\n[Component]\nЕдиный интерфейс к Ollama"):::component
        
        subgraph Agents ["Multi-Agent System"]
            direction TB
            Clarifier("Clarifier Agent\nАнализ ТЗ (System Analyst)"):::component
            Generator("Generator Agent\nГенерация (Senior Lua Dev)"):::component
            Validator("Validator Agent\nАудит кода (QA / Critic)"):::component
        end
    end

    subgraph External ["Внешние (Локальные) Процессы"]
        direction LR
        Ollama("Ollama API\n[Local Inference]\nQwen2.5/Llama3"):::external
        LuaSandbox("Sandbox\n[Process: luac]\nИзолированная проверка"):::external
    end

    %% Основной поток: Запрос
    User --> UI
    UI -- "POST /generate" --> API
    API -- "Request Contract" --> Contracts
    Contracts -- "Валидный JSON" --> Orchestrator

    %% Работа с памятью
    Orchestrator -. "1. Извлекает историю сессии" .-> DB
    Generator -. "Подтягивает правила" .-> VectorDB

    %% Сценарий 1: Уточнение (Human-in-the-loop)
    Orchestrator -- "2. Анализ ТЗ" --> Clarifier
    Clarifier -. "Статус: 'clarification'" .-> Orchestrator
    Orchestrator -. "Вопрос к пользователю" .-> UI
    UI -. "Доп. контекст" .-> User

    %% Сценарий 2: Генерация
    Orchestrator -- "3. Сборка промпта" --> Generator
    Generator -- "Отправка промпта" --> LLMClient
    
    %% Сценарий 3: Валидация (Двухэтапная)
    Orchestrator -- "4. Передача кода" --> Validator
    Validator -- "Шаг 4.1: Syntax Check" --> LuaSandbox
    Validator -- "Шаг 4.2: Logic Check (Если синтаксис OK)" --> LLMClient
    
    %% Самоисправление (Agentic Loop)
    Validator -- "Статус: 'retry' + Массив issues" --> Orchestrator
    Orchestrator -- "Шаг 5: Повторная генерация (max 3)" --> Generator
    
    %% Успешный выход или Авария
    Validator -. "Статус: 'pass' / 'abort'" .-> Orchestrator
    Orchestrator -- "Итоговый Lua код" --> API

    %% Обращение к LLM
    LLMClient -- "API Call" --> Ollama

    %% Сбор Телеметрии (Важно для Хакатона)
    API -. "Сохраняет диалог" .-> DB
    Agents -. "Токены, ms (metadata.usage)" .-> Logs
    Validator -. "Пишет temp.lua" .-> Logs

    linkStyle default stroke:#444,stroke-width:2px;
```
